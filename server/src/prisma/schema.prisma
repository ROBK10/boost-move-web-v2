generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())

  users     User[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("member")

  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])

  createdAt    DateTime @default(now())

  checkIns        DailyCheckIn[]
  minHelseCheckins MinHelseCheckin[]
  boostEntries    BoostEntry[]
}

model DailyCheckIn {
  id            String   @id @default(cuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id])

  // Én innsjekk per dag per bruker
  date          DateTime

  // Context
  context       String

  // Inputs fra bruker
  body          String
  energy        String
  movement      String

  // Spirometer-score (systemet regner, bruker ser ikke tall)
  capacityScore Int

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model BoostEntry {
  id              String   @id @default(cuid())

  userId          String
  user            User     @relation(fields: [userId], references: [id])

  type            String
  durationSeconds Int

  completedAt     DateTime @default(now())

  @@index([userId, completedAt])
}

model MinHelseCheckin {
  id            String   @id @default(cuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id])

  date          DateTime
  context       String
  capacityScore Int
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}