generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())

  users           User[]
  workplaceWishes WorkplaceWish[]
}

model WorkplaceWish {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  month     String   // "YYYY-MM"
  selected  String[]
  annetText String?
  createdAt DateTime @default(now())

  @@index([companyId, month])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("member")

  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])

  bio          String?
  avatarUrl    String?

  // Onboarding & mål
  onboardingDone Boolean  @default(false)
  weeklyGoal     Int      @default(150)
  focusPillars   String?  // JSON: ["sovn", "bevegelse"]

  // Min situasjon (kartlegging)
  healthChallenge String?  // rygg/nakke/hodepine/ingen
  biggestStruggle String?  // stress/sovn/motivasjon/smerter/ingen
  motivation      String?  // mer_energi/mindre_smerter/bedre_humor/se_barn_vokse_opp

  // Push-påminnelser
  notifyDaily    Boolean  @default(true)
  notifyTime     String   @default("09:00")

  createdAt    DateTime @default(now())

  checkIns         DailyCheckIn[]
  minHelseCheckins MinHelseCheckin[]
  boostEntries     BoostEntry[]
  messages         Message[]
  sentDMs          DirectMessage[] @relation("SentMessages")
  receivedDMs      DirectMessage[] @relation("ReceivedMessages")
  pushSubscriptions PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
}

model Message {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  text      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
}

model DirectMessage {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  text       String
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([senderId, receiverId])
}

model DailyCheckIn {
  id            String   @id @default(cuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id])

  // Én innsjekk per dag per bruker
  date          DateTime

  // Context
  context       String

  // Inputs fra bruker (5 helsepilarer)
  // movement = bevegelse (ingen/lett/moderat/aktiv)
  // body     = stillesitting (ingen_pauser/noen/regelmessig)
  // energy   = søvn (under_5/5_6/7_8/over_8)
  // context  = kosthold (ingen/1_2/3_4/5_pluss)
  // mental   = stressnivå (hoyt/middels/lavt)
  // workplace = kontekst-tag (kontor/hjemme/felt) — metadata
  body          String
  energy        String
  movement      String
  mental        String?
  workplace     String?

  // Helsescore 0–100 (sum av 5 pilarer × 20)
  capacityScore Int

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model BoostEntry {
  id              String   @id @default(cuid())

  userId          String
  user            User     @relation(fields: [userId], references: [id])

  type            String
  durationSeconds Int

  completedAt     DateTime @default(now())

  @@index([userId, completedAt])
}

model MinHelseCheckin {
  id            String   @id @default(cuid())

  userId        String
  user          User     @relation(fields: [userId], references: [id])

  date          DateTime
  context       String
  capacityScore Int
  notes         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}